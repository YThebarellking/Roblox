-- Серверный скрипт (Script) в ServerScriptService
local Players = game:GetService("Players")

local function setupCharacter(player, character)
	-- Не обрабатываем клона повторно
	if character:FindFirstChild("IsClone") then
		return
	end

	local humanoid = character:WaitForChild("Humanoid")

	-- Отображаемое здоровье (как у обычного игрока 0-100)
	local displayHealth = Instance.new("IntValue")
	displayHealth.Name = "DisplayHealth"
	displayHealth.Value = 100
	displayHealth.Parent = character

	-- Даём Humanoid огромный запас здоровья, чтобы смерть не наступала сама
	humanoid.MaxHealth = 1e6
	humanoid.Health = humanoid.MaxHealth

	local lastHealth = humanoid.Health
	local isResetting = false
	local healthChangedConn

	healthChangedConn = humanoid.HealthChanged:Connect(function(newHealth)
		if isResetting then
			lastHealth = newHealth
			return
		end

		if newHealth < lastHealth then
			local damage = lastHealth - newHealth
			-- Мгновенно восстанавливаем здоровье, не даём умереть
			isResetting = true
			humanoid.Health = humanoid.MaxHealth
			isResetting = false

			displayHealth.Value = math.max(0, displayHealth.Value - damage)

			if displayHealth.Value <= 0 then
				healthChangedConn:Disconnect()
				switchToClone(player, character)
			end
		end

		lastHealth = humanoid.Health
	end)
end

local function switchToClone(player, originalCharacter)
	-- Клонируем персонажа со всеми эффектами, одеждой, позицией и т.д.
	local clone = originalCharacter:Clone()

	-- Удаляем все скрипты, чтобы не было двойного выполнения
	for _, descendant in ipairs(clone:GetDescendants()) do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		end
	end

	-- Убираем служебное значение здоровья
	local disp = clone:FindFirstChild("DisplayHealth")
	if disp then disp:Destroy() end

	-- Настраиваем клона: здоровье всегда 100, камера и управление закрепятся за ним
	local cloneHumanoid = clone:FindFirstChild("Humanoid")
	if cloneHumanoid then
		cloneHumanoid.MaxHealth = 100
		cloneHumanoid.Health = 100
		-- Иммунитет к урону
		cloneHumanoid.HealthChanged:Connect(function(h)
			if h < 100 then
				cloneHumanoid.Health = 100
			end
		end)
	end

	-- Позиционируем клона там же, где был оригинал
	local rootPart = originalCharacter:FindFirstChild("HumanoidRootPart")
	if rootPart and clone:FindFirstChild("HumanoidRootPart") then
		clone:SetPrimaryPartCFrame(rootPart.CFrame)
	end

	clone.Name = player.Name
	-- Метка, чтобы скрипт не обработал клона как нового персонажа
	local tag = Instance.new("BoolValue")
	tag.Name = "IsClone"
	tag.Parent = clone

	clone.Parent = workspace

	-- Передаём управление и камеру клону
	local success = pcall(function()
		player:SetCharacter(clone)
	end)

	if not success then
		warn("Не удалось назначить клона персонажем")
		clone:Destroy()
		return
	end

	-- Удаляем оригинал, теперь система считает клона настоящим игроком
	task.wait(0.5)
	if originalCharacter and originalCharacter.Parent then
		originalCharacter:Destroy()
	end
end

local function onPlayerAdded(player)
	local charConn
	charConn = player.CharacterAdded:Connect(function(character)
		setupCharacter(player, character)
	end)

	-- Очистка при выходе игрока
	player.AncestryChanged:Connect(function()
		charConn:Disconnect()
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Уже зашедшие игроки
for _, player in ipairs(Players:GetPlayers()) do
	coroutine.wrap(onPlayerAdded)(player)
end
