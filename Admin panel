-- Camera Noclip
local cameraNoclipBtn = createToggleButton("Camera Noclip", funContainer, yOffsetFun)
yOffsetFun = yOffsetFun + 50

createSlider("Cam Distance", funContainer, yOffsetFun, 3, 30, cameraDistance, function(val)
    cameraDistance = val
end)
yOffsetFun = yOffsetFun + 50

userInputService.TouchStarted:Connect(function(input, processed)
    if processed then return end
    if not cameraNoclipEnabled then return end
    isTouching = true
    touchStartX = input.Position.X
    touchStartY = input.Position.Y
end)

userInputService.TouchMoved:Connect(function(input, processed)
    if processed then return end
    if not cameraNoclipEnabled or not isTouching then return end
    local deltaX = input.Position.X - touchStartX
    local deltaY = input.Position.Y - touchStartY
    local sensitivity = 0.005
    camYaw = camYaw - deltaX * sensitivity
    camPitch = math.clamp(camPitch - deltaY * sensitivity, -math.pi/2 + 0.1, math.pi/2 - 0.1)
    touchStartX = input.Position.X
    touchStartY = input.Position.Y
end)

userInputService.TouchEnded:Connect(function(input, processed)
    if processed then return end
    isTouching = false
end)

local function toggleCameraNoclip()
    cameraNoclipEnabled = not cameraNoclipEnabled
    if cameraNoclipEnabled then
        cameraNoclipBtn.Text = "Camera Noclip [ON]"
        cameraNoclipBtn.TextColor3 = Color3.fromRGB(50, 200, 50)
        camera.CameraType = Enum.CameraType.Scriptable
        camYaw = 0
        camPitch = 0
        cameraNoclipConnection = runService.RenderStepped:Connect(function()
            if not cameraNoclipEnabled then return end
            local char = player.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
            if not root then return end
            local targetPos = root.Position
            local direction = Vector3.new(
                math.cos(camPitch) * math.sin(camYaw),
                math.sin(camPitch),
                math.cos(camPitch) * math.cos(camYaw)
            )
            local camPos = targetPos - direction * cameraDistance + Vector3.new(0, 2, 0)
            camera.CFrame = CFrame.new(camPos, targetPos)
        end)
    else
        cameraNoclipBtn.Text = "Camera Noclip [OFF]"
        cameraNoclipBtn.TextColor3 = Color3.fromRGB(200, 50, 50)
        if cameraNoclipConnection then
            cameraNoclipConnection:Disconnect()
            cameraNoclipConnection = nil
        end
        camera.CameraType = Enum.CameraType.Custom
    end
end
cameraNoclipBtn.MouseButton1Click:Connect(toggleCameraNoclip)

