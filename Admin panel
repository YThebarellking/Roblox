local function createSlider(text, container, yPos, minVal, maxVal, defaultValue, step, onChanged)
    if type(step) == "function" then
        onChanged = step
        step = 1
    end
    step = step or 1

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.92, 0, 0, 38)
    frame.Position = UDim2.new(0.04, 0, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
    frame.Parent = container
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local frameStroke = Instance.new("UIStroke")
    frameStroke.Color = Color3.fromRGB(45, 45, 48)
    frameStroke.Thickness = 1
    frameStroke.Parent = frame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Position = UDim2.new(0.03, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(defaultValue)
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.GothamMedium
    label.Parent = frame

    local btnPlus = Instance.new("TextButton")
    btnPlus.Size = UDim2.new(0.18, 0, 0.7, 0)
    btnPlus.Position = UDim2.new(0.58, 0, 0.15, 0)
    btnPlus.BackgroundColor3 = Color3.fromRGB(40, 40, 44)
    btnPlus.Text = "+"
    btnPlus.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnPlus.TextSize = 14
    btnPlus.Font = Enum.Font.GothamBold
    btnPlus.Parent = frame
    Instance.new("UICorner", btnPlus).CornerRadius = UDim.new(0, 4)

    local btnMinus = Instance.new("TextButton")
    btnMinus.Size = UDim2.new(0.18, 0, 0.7, 0)
    btnMinus.Position = UDim2.new(0.78, 0, 0.15, 0)
    btnMinus.BackgroundColor3 = Color3.fromRGB(40, 40, 44)
    btnMinus.Text = "-"
    btnMinus.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnMinus.TextSize = 14
    btnMinus.Font = Enum.Font.GothamBold
    btnMinus.Parent = frame
    Instance.new("UICorner", btnMinus).CornerRadius = UDim.new(0, 4)

    local currentValue = defaultValue
    local function updateValue(newVal)
        newVal = math.clamp(newVal, minVal, maxVal)
        newVal = math.round(newVal * 10) / 10
        currentValue = newVal
        label.Text = text .. ": " .. tostring(currentValue)
        onChanged(currentValue)
    end

    btnPlus.MouseButton1Click:Connect(function() updateValue(currentValue + step) end)
    btnMinus.MouseButton1Click:Connect(function() updateValue(currentValue - step) end)

    updateValue(defaultValue)
    return frame
end

