                end
            end
        end)
    else
        antiFlingBtn.Text = "Anti Fling [OFF]"
        antiFlingBtn.TextColor3 = Color3.fromRGB(200, 50, 50)
        if antiFlingLoop then antiFlingLoop:Disconnect() antiFlingLoop = nil end
