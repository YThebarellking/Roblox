touchFlingBtn.Font = Enum.Font.SourceSansBold
touchFlingBtn.Parent = trollContainer
Instance.new("UICorner", touchFlingBtn).CornerRadius = UDim.new(0, 6)

local touchFlingActive = false
local touchFlingConnection = nil

touchFlingBtn.MouseButton1Click:Connect(function()
    touchFlingActive = not touchFlingActive
    
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

    if touchFlingActive then
        if myHRP then
            touchFlingStartPos = myHRP.CFrame
        end
        
        touchFlingBtn.Text = "Touch Fling [ON]"
        touchFlingBtn.TextColor3 = Color3.fromRGB(50, 200, 50)
        
        touchFlingConnection = runService.Heartbeat:Connect(function()
            if not touchFlingActive then return end
            
            local target = selectedPlayer
            if target and target.Character then
                local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP and myHRP then
                    myHRP.CFrame = targetHRP.CFrame * CFrame.new(math.random(-1, 1), 0, math.random(-1, 1))
                end
            end
            
            if myHRP then
                applyFlingVelocity(myHRP)
            end
        end)
    else
        touchFlingBtn.Text = "Touch Fling [OFF]"
        touchFlingBtn.TextColor3 = Color3.fromRGB(200, 50, 50)
        
        if touchFlingConnection then
            touchFlingConnection:Disconnect()
            touchFlingConnection = nil
        end
        
        if myHRP then
            myHRP.Velocity = Vector3.new(0, 0, 0)
            myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            
            if touchFlingStartPos then
                task.defer(function()
                    myHRP.CFrame = touchFlingStartPos
                    touchFlingStartPos = nil
                end)
            end
        end
    end
end)

yOffsetTroll = yOffsetTroll + 55

-- ===== ОБНОВЛЕННЫЙ Fling Teleport (работает ровно 1 сек как Touch Fling) =====
local flingTeleportBtn = Instance.new("TextButton")
flingTeleportBtn.Size = UDim2.new(0.9, 0, 0, 45)
flingTeleportBtn.Position = UDim2.new(0.05, 0, 0, yOffsetTroll)
flingTeleportBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
flingTeleportBtn.Text = "Fling Teleport"
flingTeleportBtn.TextColor3 = Color3.fromRGB(255, 200, 50)
flingTeleportBtn.TextSize = 18
flingTeleportBtn.Font = Enum.Font.SourceSansBold
flingTeleportBtn.Parent = trollContainer
Instance.new("UICorner", flingTeleportBtn).CornerRadius = UDim.new(0, 6)

flingTeleportBtn.MouseButton1Click:Connect(function()
    local target = selectedPlayer
    if not target or not target.Character then 
        print("Fling Teleport requires a target! Select a player (not None).")
        return 
    end
    
    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP or not myHRP then return end

    local myStartCF = myHRP.CFrame

    local oldCollide = {}
    for _, part in ipairs(myChar:GetChildren()) do
        if part:IsA("BasePart") then
            oldCollide[part] = part.CanCollide
            part.CanCollide = false
        end
    end

    -- Удержание на цели в течение 1 секунды (50 тиков по 0.02 сек)
    for i = 1, 50 do
        if not target.Character or not targetHRP.Parent or not myHRP.Parent then break end
        
        myHRP.CFrame = targetHRP.CFrame * CFrame.new(math.random(-1, 1), 0, math.random(-1, 1))
        applyFlingVelocity(myHRP)
        
        task.wait(0.02)
    end

    myHRP.Velocity = Vector3.new(0, 0, 0)
    myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    task.defer(function()
        myHRP.CFrame = myStartCF
        for part, collide in pairs(oldCollide) do
            if part.Parent then
                part.CanCollide = collide
            end
        end
    end)
end)

