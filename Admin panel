local function createToggleButton(text, container, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text .. " [OFF]"
    btn.TextColor3 = Color3.fromRGB(200, 50, 50)
    btn.TextSize = 15
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = container
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    return btn
end

local function createSlider(text, container, yPos, minVal, maxVal, defaultValue, onChanged)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.9, 0, 0, 40)
    frame.Position = UDim2.new(0.05, 0, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    frame.Parent = container
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.45, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(defaultValue)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.Font = Enum.Font.SourceSans
    label.Parent = frame

    local btnPlus = Instance.new("TextButton")
    btnPlus.Size = UDim2.new(0.2, 0, 0.8, 0)
    btnPlus.Position = UDim2.new(0.55, 0, 0.1, 0)
    btnPlus.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btnPlus.Text = "+"
    btnPlus.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnPlus.TextSize = 16
    btnPlus.Parent = frame
    Instance.new("UICorner", btnPlus).CornerRadius = UDim.new(0, 4)

    local btnMinus = Instance.new("TextButton")
    btnMinus.Size = UDim2.new(0.2, 0, 0.8, 0)
    btnMinus.Position = UDim2.new(0.77, 0, 0.1, 0)
    btnMinus.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btnMinus.Text = "-"
    btnMinus.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnMinus.TextSize = 16
    btnMinus.Parent = frame
    Instance.new("UICorner", btnMinus).CornerRadius = UDim.new(0, 4)

    local currentValue = defaultValue
    local function updateValue(newVal)
        newVal = math.clamp(newVal, minVal, maxVal)
        currentValue = newVal
        label.Text = text .. ": " .. tostring(currentValue)
        onChanged(currentValue)
    end

    btnPlus.MouseButton1Click:Connect(function() updateValue(currentValue + 1) end)
    btnMinus.MouseButton1Click:Connect(function() updateValue(currentValue - 1) end)

    updateValue(defaultValue)
    return frame
end

