--[[
    БЕССМЕРТИЕ v6.0 — полное удаление оригинального персонажа и подавление респавна
--]]

local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local workspace = game:GetService("Workspace")
local camera = workspace.CurrentCamera

local backupContainer = replicatedStorage:FindFirstChild("__BACKUPS__") or Instance.new("Folder")
if not backupContainer.Parent then
    backupContainer.Name = "__BACKUPS__"
    backupContainer.Parent = replicatedStorage
end

local clone = nil
local activeClone = nil
local isRespawning = false
local isCloneActive = false
local healthConnection = nil
local protectionLoop = nil
local charAddedConnection = nil

-- Создание резервной копии
local function createBackup()
    if isRespawning then return end

    local character = player.Character
    if not character then return end

    if clone then
        clone:Destroy()
        clone = nil
    end

    if not character.Archivable then
        character.Archivable = true
    end
    local newClone = character:Clone()
    character.Archivable = false

    local cloneHumanoid = newClone:FindFirstChildOfClass("Humanoid")
    if not cloneHumanoid then
        newClone:Destroy()
        return
    end

    local rootPart = newClone:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        rootPart = Instance.new("Part")
        rootPart.Name = "HumanoidRootPart"
        rootPart.Size = Vector3.new(2, 2, 1)
        rootPart.Anchored = false
        rootPart.CanCollide = true
        rootPart.Parent = newClone
        cloneHumanoid.RootPart = rootPart
        newClone.PrimaryPart = rootPart
    else
        newClone.PrimaryPart = rootPart
    end

    cloneHumanoid.Health = cloneHumanoid.MaxHealth
    cloneHumanoid.BreakJointsOnDeath = false
    cloneHumanoid.PlatformStand = false

    newClone.Parent = backupContainer
    newClone.Archivable = false

    clone = newClone
end

-- Активация клона
local function activateClone(cloneToActivate)
    if not cloneToActivate then return end
    if isRespawning then return end
    isRespawning = true

    local currentChar = player.Character
    local oldCFrame = currentChar and currentChar:GetPivot()

    -- УДАЛЯЕМ ОРИГИНАЛЬНОГО ПЕРСОНАЖА (если он не наш клон)
    if currentChar and currentChar ~= cloneToActivate then
        currentChar:Destroy()
    end

    -- Подготавливаем клона
    if not cloneToActivate.PrimaryPart then
        local root = cloneToActivate:FindFirstChild("HumanoidRootPart")
        if root then
            cloneToActivate.PrimaryPart = root
        end
    end
    if oldCFrame then
        cloneToActivate:PivotTo(oldCFrame)
    end

    local hum = cloneToActivate:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = hum.MaxHealth
        hum.BreakJointsOnDeath = false
        hum.PlatformStand = false
    end

    cloneToActivate.Parent = workspace
    player.Character = cloneToActivate
    activeClone = cloneToActivate
    isCloneActive = true

    -- Обновляем камеру
    task.wait(0.05)
    if hum then
        camera.CameraSubject = hum
    else
        camera.CameraSubject = cloneToActivate
    end

    -- Подписываемся на смерть активного клона
    if hum then
        if healthConnection then
            healthConnection:Disconnect()
            healthConnection = nil
        end
        healthConnection = hum.Died:Connect(function()
            if clone then
                activateClone(clone)
            else
                createBackup()
                if clone then
                    activateClone(clone)
                end
            end
        end)
    end

    clone = nil
    isRespawning = false

    -- Запускаем защитный цикл (подавление респавна)
    if protectionLoop then
        protectionLoop:Disconnect()
        protectionLoop = nil
    end
    protectionLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if isCloneActive and activeClone and activeClone.Parent == workspace then
            if player.Character ~= activeClone then
                player.Character = activeClone
                local h = activeClone:FindFirstChildOfClass("Humanoid")
                if h then
                    camera.CameraSubject = h
                else
                    camera.CameraSubject = activeClone
                end
            end
        end
    end)

    -- Перехватываем все новые попытки респавна и уничтожаем их
    if charAddedConnection then
        charAddedConnection:Disconnect()
        charAddedConnection = nil
    end
    charAddedConnection = player.CharacterAdded:Connect(function(newChar)
        -- Если у нас уже есть активный клон и новый персонаж - не наш клон
        if isCloneActive and newChar and newChar ~= activeClone then
            -- Уничтожаем нового персонажа сразу
            task.spawn(function()
                -- Даем игре 0.1 секунды, чтобы обработать создание, но затем удаляем
                task.wait(0.1)
                if newChar and newChar.Parent == workspace then
                    newChar:Destroy()
                end
            end)
            -- Если вдруг активный клон был удален, восстанавливаем его
            if activeClone and activeClone.Parent == workspace then
                player.Character = activeClone
            end
        end
    end)
end

-- Обработка появления персонажа (для первого запуска)
local function onCharacterAdded(character)
    if isCloneActive then return end

    createBackup()

    local humanoid = character:WaitForChild("Humanoid")
    if healthConnection then
        healthConnection:Disconnect()
        healthConnection = nil
    end
    healthConnection = humanoid.Died:Connect(function()
        if clone and not isRespawning then
            activateClone(clone)
        end
    end)
end

-- Запуск
if player.Character then
    onCharacterAdded(player.Character)
else
    player.CharacterAdded:Connect(onCharacterAdded)
end

-- Периодическое обновление резервного клона
task.spawn(function()
    while task.wait(20) do
        if not isRespawning and not isCloneActive and player.Character then
            createBackup()
        end
    end
end)

print("✅ Бессмертие v6.0 — оригинальный персонаж удалён, респавн подавлен")
