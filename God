local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local coreGui = game:GetService("CoreGui")

-- Выбираем хранилище для клонов (ReplicatedStorage предпочтительнее, CoreGui — запасной вариант)
local backupContainer = replicatedStorage:FindFirstChild("__BACKUPS__") or Instance.new("Folder")
if not backupContainer.Parent then
    backupContainer.Name = "__BACKUPS__"
    backupContainer.Parent = replicatedStorage  -- или coreGui, если replicatedStorage недоступен
end

local clone = nil
local isRespawning = false
local healthConnection = nil
local updateLoop = nil

-- Функция создания резервной копии
local function createBackup()
    if isRespawning then return end

    local character = player.Character
    if not character then return end

    -- Удаляем старый клон, чтобы не плодить мусор
    if clone then
        clone:Destroy()
        clone = nil
    end

    -- Проверяем, что персонаж можно клонировать
    if not character.Archivable then
        character.Archivable = true
    end

    local newClone = character:Clone()
    character.Archivable = false

    -- Проверяем наличие Humanoid у клона
    local cloneHumanoid = newClone:FindFirstChildOfClass("Humanoid")
    if not cloneHumanoid then
        newClone:Destroy()
        return
    end

    -- Прячем клон в контейнере
    newClone.Parent = backupContainer
    newClone.Archivable = false  -- чтобы его самого не клонировали

    clone = newClone
end

-- Функция переключения на клона
local function switchToClone()
    if isRespawning or not clone then return end
    isRespawning = true

    local currentChar = player.Character
    if currentChar then
        -- Сохраняем позицию и поворот текущего персонажа
        local oldCFrame = currentChar:GetPivot()
        
        -- Уничтожаем старого персонажа
        currentChar:Destroy()
        
        -- Перемещаем клона в мир и ставим на место оригинала
        clone:PivotTo(oldCFrame)
        clone.Parent = workspace
        player.Character = clone
    else
        -- Если персонажа не было, просто ставим клона в случайное место
        clone.Parent = workspace
        player.Character = clone
    end

    -- Обнуляем ссылку на клона (он теперь используется)
    clone = nil
    isRespawning = false

    -- Создаём нового клона для следующего раза с небольшой задержкой
    task.wait(0.2)
    createBackup()
end

-- Функция подключения обработчика смерти
local function onCharacterAdded(character)
    -- Отключаем старый обработчик, чтобы избежать утечек
    if healthConnection then
        healthConnection:Disconnect()
        healthConnection = nil
    end

    local humanoid = character:WaitForChild("Humanoid")
    
    -- Используем событие Died вместо постоянного отслеживания Health
    healthConnection = humanoid.Died:Connect(function()
        -- Защита от ошибок: если клон удалился или его нет
        if not clone or not clone.Parent then
            createBackup()
            return
        end
        
        if not isRespawning then
            switchToClone()
        end
    end)

    -- Создаём первого клона для нового персонажа
    createBackup()
end

-- Запуск при первом появлении персонажа
if player.Character then
    onCharacterAdded(player.Character)
else
    player.CharacterAdded:Connect(onCharacterAdded)
end

-- Периодическое обновление клона (раз в 10 секунд), чтобы он был актуален
-- (например, если игрок подобрал новый предмет или изменил внешность)
task.spawn(function()
    while task.wait(10) do
        if not isRespawning and player.Character then
            createBackup()
        end
    end
end)

print("✅ Улучшенный скрипт бессмертия активирован (Delta Executor)")
